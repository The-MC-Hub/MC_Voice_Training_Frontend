# MC Voice Training Frontend — Production Environment (EXAMPLE)
# Copy to .env.production and fill in real values. NEVER commit .env.production.

VITE_API_URL="https://<your-backend-domain>/api/v1"

# Google Cloud Console → APIs & Services → Credentials → OAuth client ID (Web application).
# Must match the backend's GOOGLE_CLIENT_ID.
VITE_GOOGLE_CLIENT_ID=<your-client-id>.apps.googleusercontent.com

# EmailJS — get from emailjs.com dashboard
VITE_EMAILJS_SERVICE_ID=<your-service-id>
VITE_EMAILJS_TEMPLATE_ID=<your-template-id>
VITE_EMAILJS_PUBLIC_KEY=<your-public-key>
